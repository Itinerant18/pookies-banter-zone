  "instructions_to_main_agent": [
    "Use StyleSheet.create({}) for ALL styles. DO NOT use inline styles unless for dynamic values.",
    "Implement a 'ThemeContext' to handle Dark/Light mode switching based on system preference or user toggle.",
    "Use 'AsyncStorage' to persist 'Favorites' locally.",
    "For the 'Search' feature, filter by Tool Name, Description, and Category.",
    "On 'Tool Detail' screen, use 'Linking.openURL' to open external links.",
    "Use the provided image URLs for category backgrounds or hero sections.",
    "For Tool Logos: If no specific URL is available, render a colored square with the first letter of the tool name using the Primary font.",
    "Ensure 'hitSlop={{top: 10, bottom: 10, left: 10, right: 10}}' on small TouchableOpacity elements.",
    "Use 'SafeAreaView' from 'react-native-safe-area-context'.",
    "Use 'Expo Image' for better caching and performance."
  ],
  "universal_guidelines": {
    "testing": {
      "attribute": "testID",
      "rule": "All interactive elements must have a unique testID (kebab-case)."
    },
    "accessibility": {
      "rule": "All touchables must have accessibilityLabel and accessibilityRole."
    },
    "performance": {
      "rule": "Use FlatList for lists, not ScrollView with map(). Use React.memo for list items."
    },
    "style": {
      "rule": "No 'text-align: center' globally. Center only when hierarchically necessary (e.g. Empty States)."
    }
  }
}