{
    "cli": {
        "version": ">= 7.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "EXPO_PUBLIC_CONVEX_URL": "https://festive-fish-491.eu-west-1.convex.cloud"
            }
        },
        "production": {
            "android": {
                "buildType": "app-bundle"
            },
            "env": {
                "EXPO_PUBLIC_CONVEX_URL": "https://festive-fish-491.eu-west-1.convex.cloud"
            }
        }
    },
    "submit": {
        "production": {}
    }
}